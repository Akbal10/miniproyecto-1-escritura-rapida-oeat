<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="423.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.agredo.escriturarapida.controller.GameController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 20;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5">
                    <children>
                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true">
                            <image>
                                <Image url="@icon-rune.png" />
                            </image>
                        </ImageView>

                        <Label fx:id="levelLabel"
                               text="Trial: 1"
                               style="-fx-text-fill: #f3f4f6;
                                      -fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 4, 0.2, 0, 1);" />
                    </children>
                    <HBox.margin>
                        <Insets left="30.0" top="20.0" />
                    </HBox.margin>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="5">
                    <children>
                        <ImageView fitHeight="20.0" fitWidth="20.0" preserveRatio="true">
                            <image>
                                <Image url="@icon-time.png" />
                            </image>
                        </ImageView>

                        <Label fx:id="timeLabel"
                               text="Time: 20s"
                               style="-fx-text-fill: #ffcc33;
                                      -fx-font-size: 18px;
                                      -fx-font-weight: bold;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 4, 0.2, 0, 1);" />
                    </children>
                    <HBox.margin>
                        <Insets right="30.0" top="20.0" />
                    </HBox.margin>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <children>
                <ImageView fitWidth="300.0" opacity="0.08" preserveRatio="true">
                    <image>
                        <Image url="@rune-center1.png" />
                    </image>
                </ImageView>

                <VBox alignment="CENTER"
                      maxWidth="500"
                      spacing="15"
                      style="-fx-background-color: rgba(0,0,0,0.48);
                             -fx-background-radius: 20;
                             -fx-padding: 30;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 25, 0.4, 0, 0);">
                    <children>

                        <Label fx:id="wordLabel"
                               text="Begin the Trial"
                               style="-fx-text-fill: #f4c542;
                                      -fx-font-size: 28px;
                                      -fx-font-weight: bold;
                                      -fx-effect: dropshadow(gaussian, rgba(244,197,66,0.35), 14, 0.35, 0, 0);" />

                        <TextField fx:id="inputField"
                                   onAction="#handleSubmit"
                                   prefHeight="40.0"
                                   prefWidth="420.0"
                                   promptText="Type here..."
                                   style="-fx-background-color: rgba(8,12,20,0.82);
                                          -fx-text-fill: #f8fafc;
                                          -fx-prompt-text-fill: #94a3b8;
                                          -fx-background-radius: 12;
                                          -fx-border-radius: 12;
                                          -fx-border-color: rgba(244,197,66,0.45);
                                          -fx-border-width: 1.4;
                                          -fx-padding: 10 14 10 14;
                                          -fx-font-size: 15px;" />

                        <Button fx:id="startButton"
                                onAction="#handleStart"
                                text="Enter the Abyss"
                                minWidth="190.0"
                                minHeight="42.0"
                                style="-fx-background-color: linear-gradient(to bottom, rgba(212,175,55,0.35), rgba(120,90,20,0.55));
                                       -fx-border-color: #f4c542;
                                       -fx-border-width: 1.5;
                                       -fx-border-radius: 12;
                                       -fx-background-radius: 12;
                                       -fx-text-fill: #fff4cc;
                                       -fx-padding: 10 28 10 28;
                                       -fx-font-size: 15px;
                                       -fx-font-weight: bold;
                                       -fx-effect: dropshadow(gaussian, rgba(244,197,66,0.25), 10, 0.3, 0, 0);" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="messageLabel"
                       text=""
                       style="-fx-text-fill: #cbd5e1;
                              -fx-font-size: 15px;
                              -fx-padding: 10;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 4, 0.2, 0, 1);">
                    <HBox.margin>
                        <Insets bottom="10.0" left="10.0" />
                    </HBox.margin>
                </Label>
            </children>
        </HBox>
    </bottom>

</BorderPane>
