<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="423.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.agredo.escriturarapida.controller.GameController">

    <top>
        <HBox prefHeight="3.0" prefWidth="1185.0" spacing="20">
            <children>
                <Label fx:id="levelLabel" text="Level: 1" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="timeLabel" text="Time: 20" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="15">
            <children>
                <Label fx:id="wordLabel" text="Press Start">
               <font>
                  <Font size="32.0" />
               </font></Label>
                <TextField fx:id="inputField" onAction="#handleSubmit" promptText="Type here..." />
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="15">
            <children>
                <Label fx:id="messageLabel" text="" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="startButton" onAction="#handleStart" text="Start" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
